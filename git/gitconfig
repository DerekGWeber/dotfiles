# ~/.gitconfig - symlinked from ~/dotfiles/git/gitconfig
# Last updated 2026-06-20 by Derek G. Weber

[user]
    name = Derek G. Weber
    email = derek.weber@writingrevisited.com

[github]
    user = DerekGWeber

[init]
    defaultBranch = main

[core]
    pager = diff-so-fancy | less --tabs=4 -RFX
    # editor left unset on purpose: inherits $EDITOR (nvim if present, else vim)

[interactive]
    diffFilter = diff-so-fancy --patch

[color]
    ui = true
[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = red bold 52
    newNormal = green bold
    newHighlight = green bold 22
[color "diff"]
    meta = 11
    frag = magenta bold
    func = 146 bold
    commit = yellow bold
    old = red bold
    new = green bold
    whitespace = red reverse

[pull]
    rebase = false

[push]
    default = simple
    autoSetupRemote = true

[fetch]
    prune = true

[diff]
    colorMoved = default

# Optional SSH-based commit signing. No GPG keys exist; enable later if wanted.
# Uses the per-device ed25519 key.
# [gpg]
#     format = ssh
# [user]
#     signingkey = ~/.ssh/id_ed25519_dgdw-mba-m4.pub
# [commit]
#     gpgsign = true

[include]
    path = ~/.gitconfig.local
