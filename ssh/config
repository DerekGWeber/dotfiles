# ~/.ssh/config - symlinked from ~/dotfiles/ssh/config
# Last updated 2026-06-20 by Derek G. Weber

# Per-host / private overrides (uncommitted), e.g. a different IdentityFile per device
Include ~/.ssh/config.local

Host *
    IgnoreUnknown UseKeychain
    AddKeysToAgent yes
    UseKeychain yes
    IdentityFile ~/.ssh/id_ed25519_dgdw-mba-m4
    ServerAliveInterval 60
    ServerAliveCountMax 3

